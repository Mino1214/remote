RUSTDESK_DOMAIN=rd.example.com
JWT_SECRET=replace-with-strong-random-string
ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=replace-with-strong-admin-password
RUSTDESK_API_KEY=replace-with-strong-api-key
POSTGRES_USER=rustdesk
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=rustdesk_dashboard
DATABASE_URL=postgresql://rustdesk:replace-with-strong-db-password@postgres:5432/rustdesk_dashboard

# Dashboard / NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-strong-random-string

# RustDesk API adapter
RUSTDESK_API_BASE_URL=http://rustdesk-api:21114

# Dashboard network hardening
# 쉼표로 구분된 허용 IP 목록. 비워두면 allowlist 비활성화.
# 예: 127.0.0.1,::1,10.0.0.5
DASHBOARD_IP_ALLOWLIST=

# Auth rate limit for credentials callback
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Monitoring streaming (CCTV-style screen monitoring; pure HTTPS chunked HLS)
# 외부 미디어 서버(mediamtx) 없이 dashboard 자체가 ingest/playback을 처리한다.
# 클라이언트 agent는 outbound HTTPS만 사용하므로 어느 쪽도 포트포워딩 불필요.
#
# 안전선: 동의 없는 ingest 차단, REC 워터마크 강제, 사용자 일시정지 가능.
STREAM_PLAYBACK_TOKEN_SECRET=replace-with-strong-random-secret-min-32-chars
# 재생 토큰 TTL (초).
STREAM_PLAYBACK_TOKEN_TTL=600
# 기본 녹화 보존기간 (일). DB의 Stream.retentionDays가 우선.
STREAM_RECORDINGS_DEFAULT_RETENTION_DAYS=7
# 외부에서 보이는 dashboard origin. agent에 ingest URL을 안내하는 데 쓰임.
STREAM_PUBLIC_BASE=https://admin.example.com
# 워터마크 디폴트 문구. agent가 화면에 항상 표시.
STREAM_WATERMARK_DEFAULT=● REC | 관리자 모니터링 활성화
