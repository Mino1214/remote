ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=local-dev-change-this-admin-password
RUSTDESK_API_KEY=local-dev-change-this-api-key
POSTGRES_USER=rustdesk
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rustdesk_dashboard
DATABASE_URL=postgresql://rustdesk:change-me@postgres:5432/rustdesk_dashboard

# Dashboard / NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-dev-change-this-2db178c5ea9a44f1

# RustDesk API adapter
RUSTDESK_API_BASE_URL=http://rustdesk-api:21114

# Dashboard network hardening
DASHBOARD_IP_ALLOWLIST=127.0.0.1,::1,203.0.113.10

# Auth rate limit
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Monitoring streaming subsystem (local dev values; rotate before any deploy)
STREAM_INGEST_SHARED_SECRET=local-dev-stream-ingest-shared-secret-32chars-min
STREAM_PLAYBACK_TOKEN_SECRET=local-dev-stream-playback-token-secret-32chars
STREAM_PLAYBACK_TOKEN_TTL=600
STREAM_AUTH_TRUSTED_HOSTS=mediamtx
STREAM_RECORDINGS_DEFAULT_RETENTION_DAYS=7
STREAM_PLAYBACK_HLS_BASE=http://localhost:8888
STREAM_WATERMARK_DEFAULT=● REC | 관리자 모니터링 활성화
