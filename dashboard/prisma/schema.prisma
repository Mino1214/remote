generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(OPERATOR)
  createdAt DateTime @default(now())
}

model DeviceMeta {
  id         String   @id @default(cuid())
  rustdeskId String   @unique
  alias      String?
  ownerEmail String?
  tags       String[]
  notes      String?
  blocked    Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  streams    Stream[]
}

model AccessLog {
  id           String   @id @default(cuid())
  rustdeskId   String
  remoteIp     String?
  startedAt    DateTime
  endedAt      DateTime?
  bytesRelayed BigInt   @default(0)
}

model AuditLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

// 단일 사용 provision 토큰. 평문은 발급 시 1회만 노출하고, DB에는 SHA-256 해시만 저장한다.
// 설치 파일(setup.exe)은 generic 한 개로 빌드해두고, 다운로드 시 파일명에 토큰 평문을 박아 보낸다.
// 사용 흐름:
//   1) 관리자가 대시보드에서 새 PC 등록 → 토큰 발급 → exe 다운로드
//   2) 사용자 PC에서 exe 더블클릭 → setup.iss [Code]가 자기 파일명에서 토큰 추출
//   3) /api/agent/provision 호출 → 서버는 토큰 해시로 ProvisionToken 조회 → 일치 + ACTIVE면 통과
//   4) 통과 시 status를 USED로 마킹하고 usedByDeviceId 기록 → 두 번째 사용은 차단
model ProvisionToken {
  id              String                @id @default(cuid())
  tokenHash       String                @unique
  tokenPrefix     String                // 평문 토큰의 앞 8자. UI/로그에서 식별용 (실제 검증에는 사용하지 않음)
  status          ProvisionTokenStatus  @default(ACTIVE)
  createdByEmail  String                // 발급한 관리자 이메일 (audit)
  intendedAlias   String?               // 발급 시점에 예상한 PC 별칭
  intendedOwner   String?               // 발급 시점에 예상한 소유자 이메일
  usedAt          DateTime?
  usedByDeviceId  String?               // provision 시 채워짐 (rustdeskId)
  revokedAt       DateTime?
  revokedReason   String?
  createdAt       DateTime              @default(now())

  @@index([status])
  @@index([usedByDeviceId])
}

enum ProvisionTokenStatus {
  ACTIVE       // 발급됨, 아직 사용/철회되지 않음
  USED         // 한 번 사용됨 (재사용 불가)
  REVOKED      // 관리자가 명시적으로 철회
}

// 모니터링 스트림 등록 단위. 한 디바이스가 여러 스트림(주화면/보조화면)을 가질 수 있음.
// `consentAcceptedAt`이 null인 스트림은 ingest를 거부한다 (사용자 동의 없는 스트리밍 차단).
model Stream {
  id                  String          @id @default(cuid())
  deviceId            String
  streamKey           String          @unique
  ingestSecretHash    String
  displayName         String?
  status              StreamStatus    @default(PENDING)
  consentAcceptedAt   DateTime?
  consentAcceptedBy   String?
  watermarkText       String?
  retentionDays       Int             @default(7)
  pausedAt            DateTime?
  pausedReason        String?
  lastSeenAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  device              DeviceMeta      @relation(fields: [deviceId], references: [rustdeskId], onDelete: Cascade)
  sessions            StreamSession[]
  recordings          StreamRecording[]

  @@index([deviceId])
  @@index([status])
}

model StreamSession {
  id              String    @id @default(cuid())
  streamId        String
  agentVersion    String?
  agentHostname   String?
  remoteIp        String?
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  bytesIngested   BigInt    @default(0)
  pauseCount      Int       @default(0)
  endReason       String?
  stream          Stream    @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([streamId])
  @@index([startedAt])
}

model StreamRecording {
  id          String    @id @default(cuid())
  streamId    String
  filePath    String
  startedAt   DateTime
  endedAt     DateTime?
  durationMs  Int?
  sizeBytes   BigInt?
  deletedAt   DateTime?
  stream      Stream    @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([streamId])
  @@index([startedAt])
}

enum StreamStatus {
  PENDING       // 동의 대기 (서버에 등록만 됨)
  ACTIVE        // 동의 완료, ingest 허용
  PAUSED        // 사용자가 트레이에서 일시정지
  REVOKED       // 동의 철회 또는 관리자 차단
}

enum Role {
  ADMIN
  OPERATOR
}
